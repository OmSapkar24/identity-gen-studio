# =============================================
# Identity Generation Studio — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# ---- Comet ML ----
COMET_API_KEY=your_comet_api_key_here
COMET_PROJECT_NAME=identity-gen-studio
COMET_WORKSPACE=your_comet_workspace

# ---- HuggingFace ----
HUGGINGFACE_TOKEN=your_hf_token_here

# ---- Model IDs ----
INSTANTID_MODEL_ID=InstantX/InstantID
SD_BASE_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
ANIMATEDIFF_MODEL_ID=guoyww/animatediff-motion-adapter-v1-5-2
SVD_MODEL_ID=stabilityai/stable-video-diffusion-img2vid-xt

# ---- Storage ----
# Set to 's3' or 'local'
STORAGE_BACKEND=local
LOCAL_OUTPUT_DIR=./outputs

# AWS S3 (optional, used if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ---- Backend ----
PORT=8000
WORKERS=1
LOG_LEVEL=info

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
